<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>江湖残卷 - 卡牌版</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; user-select: none; }
        :root {
            --bg: #1A1A1A; --paper: #2D2D2D; --gold: #D4AF37;
            --red: #C41E3A; --green: #3D5A3D; --blue: #3498DB;
            --purple: #9B59B6; --orange: #E67E22; --cyan: #1ABC9C;
        }
        body { font-family: "PingFang SC", "Microsoft YaHei", sans-serif; background: var(--bg); color: #E8E8E8; min-height: 100vh; display: flex; justify-content: center; }
        .screen { display: none; width: 100%; max-width: 420px; min-height: 100vh; flex-direction: column; }
        .screen.active { display: flex; }

        /* 主界面 */
        .header { text-align: center; padding: 30px 20px; background: linear-gradient(180deg, #252525, transparent); }
        .title { font-size: 22px; color: var(--gold); letter-spacing: 2px; }
        .sub { font-size: 11px; color: #666; margin-top: 4px; }
        .stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; padding: 12px 16px; }
        .stat-box { text-align: center; padding: 10px 6px; background: var(--paper); border-radius: 8px; }
        .stat-val { font-size: 18px; color: var(--gold); }
        .stat-label { font-size: 9px; color: #666; }
        .action-col { padding: 16px; display: flex; flex-direction: column; gap: 10px; }
        .btn { padding: 16px; border-radius: 12px; font-size: 14px; font-weight: bold; border: none; cursor: pointer; }
        .btn-primary { background: linear-gradient(135deg, var(--green), #2D4A2D); color: white; }
        .btn-ghost { background: #333; color: #666; font-size: 11px; }

        /* 职业选择 */
        .class-select { padding: 16px; flex: 1; overflow-y: auto; }
        .class-title { font-size: 13px; color: var(--gold); text-align: center; margin-bottom: 14px; }
        .class-list { display: flex; flex-direction: column; gap: 10px; }
        .class-card {
            display: flex; gap: 14px; padding: 14px; background: var(--paper);
            border: 2px solid #3A3A3A; border-radius: 12px; cursor: pointer; transition: all 0.2s;
        }
        .class-card:hover { border-color: var(--green); transform: translateX(4px); }
        .class-card.sel { border-color: var(--gold); background: rgba(212,175,55,0.08); }
        .class-card.sel::before { content: '✓ '; color: var(--gold); font-weight: bold; }
        .class-icon { font-size: 40px; line-height: 1; }
        .class-name { font-size: 16px; color: var(--gold); }
        .class-desc { font-size: 10px; color: #888; margin: 2px 0; }
        .class-stats { display: flex; gap: 8px; font-size: 10px; color: #666; }
        .stat-item { display: flex; align-items: center; gap: 2px; }
        .flow-tags { display: flex; gap: 4px; margin-top: 4px; }
        .flow-tag { font-size: 9px; padding: 2px 6px; border-radius: 8px; background: rgba(255,255,255,0.08); }
        .flow-tag.dps { color: var(--red); border: 1px solid var(--red); }
        .flow-tag.tank { color: var(--blue); border: 1px solid var(--blue); }
        .flow-tag.dot { color: var(--purple); border: 1px solid var(--purple); }
        .start-btn { margin: 16px; padding: 16px; background: var(--gold); color: #1A1A1A; border: none; border-radius: 12px; font-size: 14px; font-weight: bold; cursor: pointer; }
        .back-btn { margin: 0 16px 16px; padding: 10px; background: #333; color: #666; border: none; border-radius: 8px; cursor: pointer; }

        /* 战斗界面 */
        .battle-top { padding: 10px 14px; background: var(--paper); display: flex; justify-content: space-between; align-items: center; }
        .res-item { display: flex; align-items: center; gap: 4px; font-size: 13px; }
        .res-val { color: var(--gold); font-weight: bold; }
        .wave-tag { font-size: 11px; color: #888; }

        .battle-main { flex: 1; padding: 12px 14px; display: flex; flex-direction: column; }

        /* 敌人区域 */
        .enemy-area { }
        .area-label { font-size: 10px; color: #555; margin-bottom: 6px; }
        .enemy-list { display: flex; flex-direction: column; gap: 6px; }
        .enemy-card {
            display: flex; align-items: center; gap: 10px; padding: 10px 12px;
            background: rgba(196,30,58,0.08); border: 1px solid rgba(196,30,58,0.3);
            border-radius: 10px; cursor: pointer; transition: all 0.15s; position: relative;
        }
        .enemy-card:hover { background: rgba(196,30,58,0.15); }
        .enemy-card.targeted { border-color: var(--red); background: rgba(196,30,58,0.2); box-shadow: 0 0 10px rgba(196,30,58,0.3); }
        .enemy-card.dead { opacity: 0.3; cursor: default; }
        .enemy-icon { font-size: 24px; }
        .enemy-info { flex: 1; }
        .enemy-name { font-size: 12px; color: #CCC; }
        .enemy-status { font-size: 9px; color: #888; margin-top: 2px; }
        .hp-bar-bg { height: 5px; background: #333; border-radius: 3px; margin-top: 4px; }
        .hp-bar-fill { height: 100%; background: linear-gradient(90deg, var(--red), #FF6B6B); transition: width 0.3s; }
        .poison-bar-fill { height: 100%; background: linear-gradient(90deg, var(--purple), #DDA0DD); transition: width 0.3s; }
        .enemy-debuff { position: absolute; top: 3px; right: 6px; font-size: 9px; color: var(--purple); }

        .vs-divider { text-align: center; font-size: 14px; color: #444; padding: 8px 0; }

        /* 玩家区域 */
        .player-area { }
        .player-card {
            display: flex; align-items: center; gap: 10px; padding: 10px 12px;
            background: rgba(61,90,61,0.1); border: 1px solid rgba(61,90,61,0.3);
            border-radius: 10px; position: relative;
        }
        .player-icon { font-size: 28px; }
        .player-info { flex: 1; }
        .player-name { font-size: 13px; color: var(--gold); }
        .player-status { font-size: 10px; color: #888; display: flex; gap: 8px; margin-top: 2px; }
        .buff-tag { font-size: 9px; padding: 1px 4px; border-radius: 4px; }
        .buff-tag.buff { background: rgba(52,152,219,0.3); color: var(--blue); }
        .buff-tag.debuff { background: rgba(196,30,58,0.3); color: var(--red); }
        .buff-tag.special { background: rgba(155,89,182,0.3); color: var(--purple); }

        /* 手牌区 */
        .hand-area { padding: 10px 14px; background: #222; border-top: 1px solid #333; }
        .hand-label { font-size: 10px; color: #666; margin-bottom: 6px; display: flex; justify-content: space-between; }
        .hand-scroll { display: flex; gap: 6px; overflow-x: auto; padding-bottom: 4px; }
        .card-item {
            min-width: 70px; max-width: 70px; padding: 8px 4px; background: var(--paper);
            border: 1px solid #444; border-radius: 8px; text-align: center; cursor: pointer;
            transition: all 0.15s; position: relative;
        }
        .card-item:hover { transform: translateY(-4px); border-color: var(--gold); }
        .card-item:active { transform: scale(0.95); }
        .card-item.selected { border-color: var(--gold); background: rgba(212,175,55,0.15); }
        .card-item.disabled { opacity: 0.4; cursor: not-allowed; }
        .card-item.cant-play { border-color: #555; opacity: 0.5; }
        .card-icon { font-size: 22px; }
        .card-name { font-size: 9px; color: #CCC; margin-top: 2px; }
        .card-cost { position: absolute; top: 2px; right: 4px; font-size: 10px; color: var(--cyan); font-weight: bold; }
        .card-type-tag { font-size: 8px; color: #666; }
        .card-item.attack .card-type-tag { color: var(--red); }
        .card-item.defense .card-type-tag { color: var(--blue); }
        .card-item.special .card-type-tag { color: var(--purple); }
        .card-item.mobility .card-type-tag { color: var(--green); }

        /* 行动按钮 */
        .action-row { padding: 10px 14px 16px; display: flex; gap: 8px; background: #1A1A1A; }
        .action-btn { flex: 1; padding: 14px; border-radius: 10px; font-size: 13px; font-weight: bold; border: none; cursor: pointer; transition: all 0.15s; }
        .action-btn:active { transform: scale(0.96); }
        .btn-play { background: var(--red); color: white; }
        .btn-play:disabled { opacity: 0.35; cursor: not-allowed; }
        .btn-end { background: #444; color: #CCC; }
        .btn-end:disabled { opacity: 0.35; }
        .btn-heal { background: var(--green); color: white; position: relative; }
        .heal-count { position: absolute; top: 2px; right: 4px; background: var(--gold); color: #1A1A1A; font-size: 9px; padding: 1px 4px; border-radius: 6px; }

        /* 反馈 */
        .feedback { padding: 6px 14px; min-height: 32px; display: flex; align-items: center; justify-content: center; }
        .fb-text { font-size: 12px; padding: 5px 12px; border-radius: 14px; animation: fbPop 0.25s; }
        @keyframes fbPop { 0% { transform: scale(0.8); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
        .fb-text.success { background: rgba(61,90,61,0.5); color: #6BFF6B; border: 1px solid var(--green); }
        .fb-text.fail { background: rgba(196,30,58,0.5); color: #FF6B6B; border: 1px solid var(--red); }
        .fb-text.info { background: rgba(212,175,55,0.3); color: var(--gold); border: 1px solid var(--gold); }
        .fb-text.special { background: rgba(155,89,182,0.5); color: #DDA0DD; border: 1px solid var(--purple); }

        /* 飘字 */
        .dmg-pop { position: fixed; font-size: 24px; font-weight: bold; pointer-events: none; animation: floatUp 0.8s forwards; z-index: 500; }
        .dmg-pop.dmg { color: #FF4444; }
        .dmg-pop.crit { color: #FFD700; font-size: 30px; }
        .dmg-pop.heal { color: #44FF44; }
        .dmg-pop.miss { color: #888; font-size: 16px; }
        .dmg-pop.poison { color: #DDA0DD; font-size: 18px; }
        .dmg-pop.reflect { color: var(--orange); font-size: 18px; }
        @keyframes floatUp { 0% { opacity: 1; transform: translateY(0) scale(1.2); } 100% { opacity: 0; transform: translateY(-60px) scale(0.7); } }

        /* 弹窗 */
        .modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.92); z-index: 1000; display: flex; align-items: center; justify-content: center; }
        .modal-content { background: var(--paper); border: 2px solid var(--gold); border-radius: 16px; padding: 24px; max-width: 380px; width: 94%; }
        .modal-icon { text-align: center; font-size: 56px; margin-bottom: 12px; }
        .modal-title { text-align: center; font-size: 20px; color: var(--gold); margin-bottom: 8px; }
        .modal-desc { text-align: center; font-size: 13px; color: #AAA; line-height: 1.6; margin-bottom: 20px; }
        .modal-choices { display: flex; flex-direction: column; gap: 8px; }
        .choice-btn { padding: 12px; border-radius: 8px; cursor: pointer; border: 1px solid #444; background: rgba(255,255,255,0.04); transition: all 0.15s; text-align: left; }
        .choice-btn:hover { border-color: var(--gold); transform: translateX(4px); }
        .choice-name { color: #EEE; font-size: 13px; font-weight: bold; }
        .choice-desc { color: #888; font-size: 11px; margin-top: 3px; }
        .choice-cost { color: var(--gold); font-size: 10px; margin-top: 3px; }

        /* 波次提示 */
        .wave-banner { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); font-size: 36px; color: var(--gold); font-weight: bold; text-shadow: 0 0 30px var(--gold); z-index: 600; animation: waveFlash 1.5s forwards; pointer-events: none; }
        @keyframes waveFlash { 0%{opacity:0;transform:translate(-50%,-50%) scale(0.3)}20%{opacity:1;transform:translate(-50%,-50%) scale(1.2)}80%{opacity:1}100%{opacity:0} }

        /* 章节结束选卡 */
        .card-pick { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.95); z-index: 1000; display: flex; flex-direction: column; }
        .pick-header { padding: 20px; text-align: center; }
        .pick-title { font-size: 18px; color: var(--gold); }
        .pick-sub { font-size: 12px; color: #666; margin-top: 4px; }
        .pick-cards { flex: 1; padding: 16px; display: flex; flex-direction: column; gap: 12px; overflow-y: auto; }
        .pick-card {
            display: flex; gap: 14px; padding: 16px; background: var(--paper);
            border: 2px solid #444; border-radius: 12px; cursor: pointer; transition: all 0.2s;
        }
        .pick-card:hover { border-color: var(--gold); transform: translateY(-3px); }
        .pick-card-icon { font-size: 40px; }
        .pick-card-info { flex: 1; }
        .pick-card-name { font-size: 15px; color: var(--gold); }
        .pick-card-type { font-size: 10px; color: #666; margin: 2px 0; }
        .pick-card-effect { font-size: 12px; color: #CCC; line-height: 1.4; }
        .pick-card-rarity { font-size: 10px; padding: 2px 6px; border-radius: 6px; }
        .pick-card-rarity.rare { background: rgba(52,152,219,0.3); color: var(--blue); }
        .pick-card-rarity.epic { background: rgba(155,89,182,0.3); color: var(--purple); }
        .pick-card-rarity.legend { background: rgba(212,175,55,0.3); color: var(--gold); }
    </style>
</head>
<body>
    <!-- 主界面 -->
    <div class="screen active" id="screenMain">
        <div class="header">
            <div class="title">江湖残卷</div>
            <div class="sub">卡牌Roguelike · 流派构筑</div>
        </div>
        <div class="stats-grid">
            <div class="stat-box"><div class="stat-val" id="stRuns">0</div><div class="stat-label">总局数</div></div>
            <div class="stat-box"><div class="stat-val" id="stWins">0</div><div class="stat-label">通关</div></div>
            <div class="stat-box"><div class="stat-val" id="stBest">0</div><div class="stat-label">最佳章节</div></div>
            <div class="stat-box"><div class="stat-val" id="stCards">0</div><div class="stat-label">已解锁卡</div></div>
        </div>
        <div class="action-col" style="flex:1;">
            <button class="btn btn-primary" onclick="showScreen('screenClass')">🗡️ 开始探索</button>
            <button class="btn btn-ghost" onclick="resetAll()">🔄 重置进度</button>
        </div>
    </div>

    <!-- 职业选择 -->
    <div class="screen" id="screenClass">
        <div class="class-select">
            <div class="class-title">🎯 选择你的职业</div>
            <div class="class-list" id="classList"></div>
        </div>
        <button class="start-btn" onclick="confirmClass()">确认 · 开始冒险</button>
        <button class="back-btn" onclick="showScreen('screenMain')">← 返回</button>
    </div>

    <!-- 战斗界面 -->
    <div class="screen" id="screenBattle">
        <div class="battle-top">
            <div class="res-item"><span>💰</span><span class="res-val" id="rGold">0</span></div>
            <div class="wave-tag">章节 <span id="rChapter">1</span> - <span id="rWave">1</span>/3</div>
            <div class="res-item"><span>⚡</span><span class="res-val" id="rEnergy">3</span>/<span id="rMaxEnergy">6</span></div>
        </div>
        <div class="battle-main">
            <div class="enemy-area">
                <div class="area-label">敌方</div>
                <div class="enemy-list" id="enemyList"></div>
            </div>
            <div class="vs-divider">⚔ 战 ⚔</div>
            <div class="player-area">
                <div class="area-label">我方</div>
                <div class="player-card" id="playerCard"></div>
            </div>
        </div>
        <div class="feedback" id="feedback"></div>
        <div class="hand-area">
            <div class="hand-label">
                <span>🃏 手牌 <span id="handCount">0</span>/8</span>
                <span id="turnInfo">回合 1</span>
            </div>
            <div class="hand-scroll" id="handList"></div>
        </div>
        <div class="action-row">
            <button class="action-btn btn-play" id="btnPlay" onclick="playCard()">⚔️ 出牌</button>
            <button class="action-btn btn-heal" id="btnHeal" onclick="useHeal()" style="flex:0.6;">
                💊<span class="heal-count" id="healCount">0</span>
            </button>
            <button class="action-btn btn-end" id="btnEnd" onclick="endTurn()">结束回合</button>
        </div>
    </div>

    <!-- 弹窗 -->
    <div class="modal" id="modal" style="display:none">
        <div class="modal-content">
            <div class="modal-icon" id="mIcon">🏺</div>
            <div class="modal-title" id="mTitle">事件</div>
            <div class="modal-desc" id="mDesc">描述</div>
            <div class="modal-choices" id="mChoices"></div>
        </div>
    </div>

    <!-- 选卡弹窗 -->
    <div class="card-pick" id="cardPick" style="display:none">
        <div class="pick-header">
            <div class="pick-title">📜 选择一张卡牌</div>
            <div class="pick-sub">新卡牌将永久解锁</div>
        </div>
        <div class="pick-cards" id="pickCards"></div>
    </div>

    <script>
    // ==================== 卡牌数据 ====================
    const ALL_CARDS = {
        // 剑侠基础
        sword_basic_1: { id: 'sword_basic_1', name: '平刺', icon: '⚔️', type: 'attack', cost: 1, rarity: 'basic', desc: '造成8点伤害', effect: 'damage', value: 8, class: 'sword' },
        sword_basic_2: { id: 'sword_basic_2', name: '上挑', icon: '↗️', type: 'attack', cost: 0, rarity: 'basic', desc: '造成6点伤害，打出后抽1张牌，本牌0费', effect: 'damage_draw', value: 6, class: 'sword' },
        sword_basic_3: { id: 'sword_basic_3', name: '剑舞', icon: '💫', type: 'attack', cost: 2, rarity: 'basic', desc: '造成5点伤害2次', effect: 'damage_x2', value: 5, class: 'sword' },
        sword_basic_4: { id: 'sword_basic_4', name: '破甲斩', icon: '⛰️', type: 'attack', cost: 2, rarity: 'basic', desc: '造成12点伤害，忽视敌人10%防御', effect: 'damage_armor_ignore', value: 12, ignorePct: 0.1, class: 'sword' },
        sword_basic_5: { id: 'sword_basic_5', name: '蓄力', icon: '🔥', type: 'special', cost: 1, rarity: 'basic', desc: '本次攻击伤害+60%', effect: 'buff_damage', value: 0.6, class: 'sword' },

        // 刺客基础
        assassin_basic_1: { id: 'assassin_basic_1', name: '暗刺', icon: '🗡️', type: 'attack', cost: 1, rarity: 'basic', desc: '造成10点伤害，必中', effect: 'damage', value: 10, class: 'assassin' },
        assassin_basic_2: { id: 'assassin_basic_2', name: '淬毒', icon: '☠️', type: 'special', cost: 2, rarity: 'basic', desc: '敌人中毒3回合，每回合-4血', effect: 'poison', value: 4, turns: 3, class: 'assassin' },
        assassin_basic_3: { id: 'assassin_basic_3', name: '毒刃', icon: '🩸', type: 'attack', cost: 2, rarity: 'basic', desc: '造成6点伤害+中毒2回合', effect: 'damage_poison', value: 6, poisonValue: 4, poisonTurns: 2, class: 'assassin' },
        assassin_basic_4: { id: 'assassin_basic_4', name: '致命一击', icon: '💀', type: 'attack', cost: 2, rarity: 'basic', desc: '造成12点伤害，若敌人满血暴击率+60%', effect: 'damage_crit_if_full', value: 12, class: 'assassin' },
        assassin_basic_5: { id: 'assassin_basic_5', name: '瞬闪', icon: '💨', type: 'mobility', cost: 1, rarity: 'basic', desc: '本回合闪避率+30%', effect: 'buff_evade', value: 0.3, class: 'assassin' },

        // 武僧基础
        monk_basic_1: { id: 'monk_basic_1', name: '金刚拳', icon: '👊', type: 'attack', cost: 2, rarity: 'basic', desc: '造成12点伤害+本次受伤反伤30%', effect: 'damage_revenge', value: 12, revengePct: 0.3, class: 'monk' },
        monk_basic_2: { id: 'monk_basic_2', name: '铁山靠', icon: '🛡️', type: 'defense', cost: 1, rarity: 'basic', desc: '格挡10点伤害', effect: 'block', value: 10, class: 'monk' },
        monk_basic_3: { id: 'monk_basic_3', name: '反伤震', icon: '⚡', type: 'special', cost: 2, rarity: 'basic', desc: '本回合受伤反弹60%伤害', effect: 'revenge_all', value: 0.6, class: 'monk' },
        monk_basic_4: { id: 'monk_basic_4', name: '醉拳闪', icon: '🍶', type: 'mobility', cost: 2, rarity: 'basic', desc: '35%闪避，闪避成功后下回合攻击+5', effect: 'evade_attack', evadePct: 0.35, attackBonus: 5, class: 'monk' },
        monk_basic_5: { id: 'monk_basic_5', name: '无相转', icon: '🔄', type: 'defense', cost: 2, rarity: 'basic', desc: '格挡1次伤害，转移给随机敌人', effect: 'block_transfer', value: 1, class: 'monk' },

        // 萨满基础
        shaman_basic_1: { id: 'shaman_basic_1', name: '治疗符', icon: '💚', type: 'special', cost: 2, rarity: 'basic', desc: '恢复12点生命', effect: 'heal', value: 12, class: 'shaman' },
        shaman_basic_2: { id: 'shaman_basic_2', name: '噬魂击', icon: '💜', type: 'attack', cost: 2, rarity: 'basic', desc: '消耗12血，造成25伤害', effect: 'sacrifice_damage', costHp: 12, value: 25, class: 'shaman' },
        shaman_basic_3: { id: 'shaman_basic_3', name: '护盾术', icon: '🔮', type: 'defense', cost: 2, rarity: 'basic', desc: '获得18点护盾', effect: 'shield', value: 18, class: 'shaman' },
