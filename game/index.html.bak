    // ==================== 游戏状态 ====================
    let G = {};

    function initGame() {
        G = {
            phase: 'main',
            player: null,
            deck: [], hand: [], discard: [],
            enemies: [],
            gold: 0,
            healPots: 0,
            energy: 0, maxEnergy: 6,
            turn: 1,
            wave: 1, maxWave: 3,
            chapter: 1, maxChapter: 5,
            targetEnemy: null,
            selectedCard: null,
            // 战斗状态
            block: 0,
            shield: 0,
            thorns: 0,
            shieldReflect: false,
            evadeBuff: 0,
            evadeBuffTurns: 0,
            revengeBuff: 0,
            revengeAll: false,
            immune: false,
            immortalTriggered: false,
            damageBuff: 0,
            critBuff: 0,
            critDmgBonus: 0,
            attackCountBonus: 0,
            chainUsed: false,
            bloodDemonAtk: 0,
            // 永久
            permanent: { runs: 0, wins: 0, bestChapter: 0, unlockedCards: [], unlockedMeridians: [] },
        };
    }

    // ==================== 存储 ====================
    function loadData() {
        const s = localStorage.getItem('jianghu_card_v1');
        if (s) G.permanent = JSON.parse(s);
    }
    function saveData() {
        localStorage.setItem('jianghu_card_v1', JSON.stringify({
            runs: G.permanent.runs, wins: G.permanent.wins, bestChapter: G.permanent.bestChapter,
            unlockedCards: G.permanent.unlockedCards,
        }));
    }
    function resetAll() {
        if (confirm('重置所有进度？')) { localStorage.removeItem('jianghu_card_v1'); location.reload(); }
    }

    // ==================== 界面 ====================
    function showScreen(id) {
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById(id).classList.add('active');
    }

    function updateMain() {
        document.getElementById('stRuns').textContent = G.permanent.runs;
        document.getElementById('stWins').textContent = G.permanent.wins;
        document.getElementById('stBest').textContent = G.permanent.bestChapter;
        document.getElementById('stCards').textContent = (G.permanent.unlockedCards || []).length;
    }

    // ==================== 职业选择 ====================
    let selClass = 'sword';
    function showClassSelect() {
        const list = document.getElementById('classList');
        list.innerHTML = '';
        Object.entries(CLASSES).forEach(([id, c]) => {
            const card = document.createElement('div');
            card.className = 'class-card' + (id === selClass ? ' sel' : '');
            card.innerHTML = `
                <div class="class-icon">${c.icon}</div>
                <div>
                    <div class="class-name">${c.name}</div>
                    <div class="class-desc">${c.desc}</div>
                    <div class="class-stats">
                        <span class="stat-item">❤️${c.hp}</span>
                        <span class="stat-item">⚔️${c.atk}</span>
                        <span class="stat-item">🛡️${c.def}</span>
                        <span class="stat-item">💨${Math.floor(c.evade*100)}%</span>
                    </div>
                    <div class="flow-tags">
                        ${c.flows.map(f => `<span class="flow-tag ${f.tag}">${f.name}</span>`).join('')}
                    </div>
                </div>
            `;
            card.onclick = () => {
                document.querySelectorAll('.class-card').forEach(c => c.classList.remove('sel'));
                card.classList.add('sel');
                selClass = id;
            };
            list.appendChild(card);
        });
    }

    function confirmClass() {
        const cls = CLASSES[selClass];
        G.permanent.runs++;
        saveData();

        // 初始化玩家
        G.player = {
            class: selClass, name: cls.name, icon: cls.icon,
            hp: cls.hp, maxHp: cls.hp, atk: cls.atk, def: cls.def, evade: cls.evade,
        };
        G.maxEnergy = cls.maxEnergy;
        G.energy = cls.energy;
        G.energyRegen = cls.energyRegen;

        // 构建初始牌组
        const basicIds = [...cls.basicCards];
        // 加入已解锁的同职业卡
        (G.permanent.unlockedCards || []).forEach(id => {
            const card = ALL_CARDS[id];
            if (card && card.class === selClass) basicIds.push(id);
        });
        G.deck = basicIds.map(id => ({...ALL_CARDS[id], id: id + '_' + Math.random().toString(36).substr(2,5)}));
        G.hand = []; G.discard = [];
        G.gold = 0; G.healPots = 0;
        G.wave = 1; G.chapter = 1; G.turn = 1;

        // 重置战斗状态
        resetBattleState();

        showScreen('screenBattle');
        showWaveBanner(`章节 ${G.chapter} - 第 ${G.wave} 波`);
        spawnEnemies();
        drawCards(3);
        renderAll();
    }

    function resetBattleState() {
        G.block = 0; G.shield = 0; G.thorns = 0; G.shieldReflect = false;
        G.evadeBuff = 0; G.evadeBuffTurns = 0;
        G.revengeBuff = 0; G.revengeAll = false;
        G.immune = false; G.immortalTriggered = false;
        G.damageBuff = 0; G.critBuff = 0; G.critDmgBonus = 0;
        G.attackCountBonus = 0; G.chainUsed = false;
        G.bloodDemonAtk = 0;
    }

    // ==================== 战斗系统 ====================
    function spawnEnemies() {
        G.enemies = [];
        const isBoss = G.wave === G.maxWave;
        const clsDmgMult = 0.8 + G.chapter * 0.15;

        if (isBoss) {
            const boss = BOSS_TEMPLATES[G.chapter - 1] || BOSS_TEMPLATES[0];
            G.enemies.push({...boss, hp: Math.floor(boss.hp * clsDmgMult), maxHp: Math.floor(boss.hp * clsDmgMult)});
        } else {
            const count = Math.min(G.wave + 1, 3);
            const usedNames = new Set();
            for (let i = 0; i < count; i++) {
                let tmpl;
                do { tmpl = ENEMY_TEMPLATES[Math.floor(Math.random() * ENEMY_TEMPLATES.length)]; }
                while (usedNames.has(tmpl.name) && usedNames.size < ENEMY_TEMPLATES.length);
                usedNames.add(tmpl.name);
                G.enemies.push({
                    ...tmpl,
                    hp: Math.floor(tmpl.hp * clsDmgMult),
                    maxHp: Math.floor(tmpl.hp * clsDmgMult),
                    poison: 0, poisonTurns: 0,
                    marked: false, markedTurns: 0,
                });
            }
        }
    }

    function drawCards(n) {
        for (let i = 0; i < n; i++) {
            if (G.hand.length >= 8) break;
            if (G.deck.length === 0) {
                if (G.discard.length === 0) break;
                G.deck = [...G.discard];
                G.discard = [];
                shuffle(G.deck);
            }
            if (G.deck.length > 0) G.hand.push(G.deck.pop());
        }
    }

    function shuffle(arr) { for (let i = arr.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [arr[i], arr[j]] = [arr[j], arr[i]]; } }

    function renderAll() {
        renderEnemies();
        renderPlayer();
        renderHand();
        document.getElementById('rGold').textContent = G.gold;
        document.getElementById('rChapter').textContent = G.chapter;
        document.getElementById('rWave').textContent = G.wave;
        document.getElementById('rEnergy').textContent = G.energy;
        document.getElementById('rMaxEnergy').textContent = G.maxEnergy;
        document.getElementById('healCount').textContent = G.healPots;
        document.getElementById('turnInfo').textContent = `回合 ${G.turn}`;
        document.getElementById('btnHeal').disabled = G.healPots <= 0;
    }

    function renderEnemies() {
        const list = document.getElementById('enemyList');
        list.innerHTML = '';
        G.enemies.forEach((e, i) => {
            const dead = e.hp <= 0;
            const targeted = G.targetEnemy === i;
            const poisonStr = e.poison > 0 ? `☠️${e.poison}/${e.poisonTurns}` : '';
            const markStr = e.marked ? '💀易伤' : '';
            const debuff = poisonStr || markStr;
            list.innerHTML += `
                <div class="enemy-card ${dead ? 'dead' : ''} ${targeted ? 'targeted' : ''}" onclick="selectEnemy(${i})">
                    ${debuff ? `<div class="enemy-debuff">${debuff}</div>` : ''}
                    <div class="enemy-icon">${e.icon}</div>
                    <div class="enemy-info">
                        <div class="enemy-name">${e.name}</div>
                        <div class="enemy-status">⚔️${e.atk} 🛡️${e.def}</div>
                        <div class="hp-bar-bg">
                            <div class="hp-bar-fill" style="width:${Math.max(0, e.hp/e.maxHp*100)}%"></div>
                        </div>
                    </div>
                </div>
            `;
        });
    }

    function renderPlayer() {
        const p = G.player;
        let buffs = [];
        if (G.evadeBuff > 0) buffs.push(`<span class="buff-tag buff">闪避+${Math.floor(G.evadeBuff*100)}%${G.evadeBuffTurns > 1 ? `×${G.evadeBuffTurns}` : ''}</span>`);
        if (G.block > 0) buffs.push(`<span class="buff-tag buff">格挡${G.block}</span>`);
        if (G.shield > 0) buffs.push(`<span class="buff-tag buff">护盾${G.shield}</span>`);
        if (G.thorns > 0) buffs.push(`<span class="buff-tag special">荆棘${G.thorns}</span>`);
        if (G.revengeBuff > 0 || G.revengeAll) buffs.push(`<span class="buff-tag special">反伤${Math.floor((G.revengeBuff || G.revengeAll ? 0.6 : 0)*100)}%</span>`);
        if (G.damageBuff > 0) buffs.push(`<span class="buff-tag buff">攻击+${Math.floor(G.damageBuff*100)}%</span>`);
        if (G.critBuff > 0) buffs.push(`<span class="buff-tag buff">暴击+${Math.floor(G.critBuff*100)}%</span>`);
        if (G.immune) buffs.push(`<span class="buff-tag special">免疫</span>`);
        if (G.immortalTriggered) buffs.push(`<span class="buff-tag special">不死</span>`);

        document.getElementById('playerCard').innerHTML = `
            <div class="player-icon">${p.icon}</div>
            <div class="player-info">
                <div class="player-name">${p.name}</div>
                <div class="player-status">
                    <span>❤️${p.hp}/${p.maxHp}</span>
                    <span>⚔️${p.atk}</span>
                    <span>🛡️${p.def}</span>
                </div>
                ${buffs.length ? `<div style="margin-top:4px;display:flex;gap:4px;flex-wrap:wrap;">${buffs.join('')}</div>` : ''}
            </div>
        `;
    }

    function renderHand() {
        const list = document.getElementById('handList');
        list.innerHTML = '';
        document.getElementById('handCount').textContent = G.hand.length;

        G.hand.forEach((card, i) => {
            const canPlay = G.energy >= card.cost && G.targetEnemy !== null;
            const sel = G.selectedCard === i;
            const cls = card.cost === 0 ? 'selected' : '';

            // 检查萨满扣血
            let cantPlay = false;
            if (card.effect === 'sacrifice_damage' || card.effect === 'sacrifice_aoe' || card.effect === 'sacrifice_big') {
                const costHp = card.costHp || Math.floor(G.player.hp * card.costPct);
                if (G.player.hp <= costHp) cantPlay = true;
            }

            list.innerHTML += `
                <div class="card-item ${card.type} ${sel ? 'selected' : ''} ${!canPlay || cantPlay ? 'cant-play' : ''}"
                     onclick="selectCard(${i})">
                    <div class="card-cost">⚡${card.cost}</div>
                    <div class="card-icon">${card.icon}</div>
                    <div class="card-name">${card.name}</div>
                    <div class="card-type-tag">${card.type === 'attack' ? '攻' : card.type === 'defense' ? '防' : card.type === 'mobility' ? '机' : '特'}</div>
                </div>
            `;
        });

        document.getElementById('btnPlay').disabled = G.selectedCard === null;
    }

    function selectEnemy(idx) {
        if (G.enemies[idx].hp <= 0) return;
        G.targetEnemy = idx;
        renderEnemies();
        renderHand();
    }

    function selectCard(idx) {
        const card = G.hand[idx];
        if (G.energy < card.cost) { showFB('气力不足！', 'fail'); return; }
        if (!G.targetEnemy && card.type === 'attack') { showFB('请先选择目标！', 'info'); return; }
        G.selectedCard = idx;
        renderHand();
    }

    // ==================== 出牌 ====================
    function playCard() {
        if (G.selectedCard === null) return;
        const card = G.hand[G.selectedCard];
        if (G.energy < card.cost) { showFB('气力不足！', 'fail'); return; }

        G.energy -= card.cost;
        G.hand.splice(G.selectedCard, 1);
        G.discard.push(card);
        G.selectedCard = null;

        executeCard(card);
        renderAll();

        // 检查
        checkDead();
    }

    function executeCard(card) {
        const enemy = G.targetEnemy !== null ? G.enemies[G.targetEnemy] : null;

        switch (card.effect) {
            // 基础伤害
            case 'damage':
                if (enemy) dealDamage(enemy, card.value);
                break;

            // 伤害+抽牌(上挑)
            case 'damage_draw':
                if (enemy) dealDamage(enemy, card.value);
                drawCards(1);
                showFB('抽1张牌！', 'success');
                break;

            // 伤害2次
            case 'damage_x2':
                for (let i = 0; i < 2; i++) { if (enemy && enemy.hp > 0) dealDamage(enemy, card.value); }
                break;

            // 伤害+忽视防御
            case 'damage_armor_ignore':
                if (enemy) dealDamage(enemy, card.value, 0, card.ignorePct || 0);
                break;

            // 伤害增益
            case 'damage_crit_if_full':
                if (enemy) {
                    const critBonus = enemy.hp === enemy.maxHp ? card.critPct || 0.6 : 0;
                    const dmg = dealDamage(enemy, card.value);
                    if (critBonus > 0 && Math.random() < critBonus) {
                        const critDmg = Math.floor(dmg * (2 + G.critDmgBonus));
                        enemy.hp -= critDmg;
                        showDmgPop(critDmg, 'crit');
                    }
                }
                break;

            // 伤害×2.5 若满血
            case 'damage_if_full':
                if (enemy) {
                    const mult = enemy.hp === enemy.maxHp ? 2.5 : 1;
                    dealDamage(enemy, Math.floor(card.value * mult));
                }
                break;

            // 连环剑
            case 'damage_chain':
                if (enemy) {
                    dealDamage(enemy, card.value);
                    let pct = card.chainPct || 0.35;
                    while (Math.random() < pct && enemy.hp > 0) {
                        dealDamage(enemy, card.value);
                        pct *= 0.6; // 递减
                    }
                }
                break;

            // 多段攻击
            case 'damage_multistrike':
                if (enemy) {
                    let val = card.baseValue;
                    for (let i = 0; i < (card.hits || 4); i++) {
                        if (enemy.hp <= 0) break;
                        dealDamage(enemy, Math.floor(val));
                        val *= 0.85;
                    }
                }
                break;

            // 无视防御
            case 'damage_ignore_kill':
                if (enemy) {
                    const killed = enemy.hp - dealDamage(enemy, card.value, 1) <= 0;
                    if (killed) {
                        G.chainUsed = true; // 重置效果暂用此标志
                        showFB('击杀重置！', 'special');
                    }
                }
                break;

            // 固定暴击率
            case 'damage_crit_fixed':
                if (enemy) {
                    if (Math.random() < (card.critPct || 0.6)) {
                        dealDamage(enemy, Math.floor(card.value * (2 + G.critDmgBonus)), 0, 0, true);
                    } else {
                        dealDamage(enemy, card.value);
                    }
                }
                break;

            // 百分比伤害
            case 'damage_percent':
                if (enemy) {
                    dealDamage(enemy, Math.floor(enemy.hp * (card.value || 0.4)));
                }
                break;

            // 无视闪避
            case 'damage_true':
                if (enemy) dealDamage(enemy, card.value, 2);
                break;

            // 毒伤
            case 'poison':
                if (enemy) { enemy.poison = (enemy.poison || 0) + (card.value || 4); enemy.poisonTurns = card.turns || 3; showFB(`${enemy.name}中毒！`, 'special'); }
                break;

            // AOE毒
            case 'poison_aoe':
                G.enemies.filter(e => e.hp > 0).forEach(e => { e.poison = (e.poison || 0) + (card.value || 3); e.poisonTurns = card.turns || 2; });
                showFB('全体中毒！', 'special');
                break;

            // 毒爆
            case 'damage_poison_explode':
                if (enemy) {
                    const poisonDmg = (enemy.poison || 0) * (card.value || 8);
                    enemy.hp -= poisonDmg;
                    showDmgPop(poisonDmg, 'poison');
                    enemy.poison = 0; enemy.poisonTurns = 0;
                }
                break;

            // 永久毒
            case 'poison_permanent':
                G.enemies.filter(e => e.hp > 0).forEach(e => { e.poison = (e.poison || 0) + (card.value || 2); e.poisonTurns = 999; });
                showFB('永久中毒！', 'special');
                break;

            // 标记
            case 'mark':
                if (enemy) { enemy.marked = true; enemy.markedTurns = card.turns || 3; showFB('标记！+80%易伤', 'special'); }
                break;

            // 伤害+毒
            case 'damage_poison':
                if (enemy) {
                    dealDamage(enemy, card.value);
                    enemy.poison = (enemy.poison || 0) + (card.poisonValue || 4);
                    enemy.poisonTurns = card.poisonTurns || 2;
                    showFB('附加中毒！', 'special');
                }
                break;

            // 增益-伤害
            case 'buff_damage':
                G.damageBuff = Math.max(G.damageBuff, card.value || 0.6);
                showFB(`攻击+${Math.floor((card.value || 0.6)*100)}%！`, 'info');
                break;

            // 增益-暴击
            case 'buff_crit':
                G.critBuff = Math.max(G.critBuff, card.value || 0.6);
                showFB(`暴击+${Math.floor((card.value || 0.6)*100)}%！`, 'info');
                break;

            // 暴击+伤害
            case 'buff_crit_damage':
                G.damageBuff = Math.max(G.damageBuff, card.value || 0.4);
                G.critDmgBonus = Math.max(G.critDmgBonus, card.critBonus || 0.5);
                showFB('暴击强化！', 'info');
                break;

            // 全攻击增益
            case 'buff_all_attack':
                G.attackCountBonus += card.value || 3;
                showFB(`攻击+${card.value}！`, 'info');
                break;

            // 闪避
            case 'buff_evade':
                G.evadeBuff = Math.max(G.evadeBuff, card.value || 0.3);
                G.evadeBuffTurns = 1;
                showFB(`闪避+${Math.floor((card.value || 0.3)*100)}%！`, 'info');
                break;

            // 闪避+反击
            case 'evade_attack':
                G.evadeBuff = Math.max(G.evadeBuff, card.evadePct || 0.35);
                G.evadeBuffTurns = 1;
                G.revengeBuff = Math.max(G.revengeBuff, 0.3); // 闪避后获得反击
                showFB('醉拳闪！', 'info');
                break;

            // 闪避后攻击
            case 'evade_then_attack':
                G.evadeBuff = Math.max(G.evadeBuff, card.evadePct || 0.5);
                G.evadeBuffTurns = 1;
                G.damageBuff = Math.max(G.damageBuff, 0);
                showFB(`闪避${Math.floor((card.evadePct||0.5)*100)}%！`, 'info');
                break;

            // 长时间闪避
            case 'evade_long':
                G.evadeBuff = Math.max(G.evadeBuff, card.evadePct || 0.4);
                G.evadeBuffTurns = card.turns || 2;
                showFB(`闪避${Math.floor((card.evadePct||0.4)*100)}%×${G.evadeBuffTurns}回合`, 'info');
                break;

            // 闪避反击
            case 'evade_counter':
                G.evadeBuff = 1; // 必定闪避
                G.evadeBuffTurns = card.evadeCount || 3;
                G.revengeBuff = Math.max(G.revengeBuff, 0.8);
                showFB(`幻影迷踪！`, 'special');
                break;

            // 全闪避反击
            case 'evade_all_counter':
                G.evadeBuff = 1;
                G.evadeBuffTurns = 99;
                G.revengeBuff = Math.max(G.revengeBuff, 0.8);
                showFB(`逍遥游！`, 'special');
                break;

            // 格挡
            case 'block':
                G.block += card.value || 10;
                showFB(`格挡+${card.value || 10}！`, 'info');
                break;

            // 格挡转移
            case 'block_transfer':
                G.block += card.value || 1;
                G.shieldReflect = true;
                showFB('无相转！格挡并转移伤害', 'info');
                break;

            // 护盾
            case 'shield':
                G.shield += card.value || 18;
                showFB(`护盾+${card.value || 18}！`, 'info');
                break;

            // 荆棘护盾
            case 'thorns_shield':
                G.shield += card.shield || 20;
                G.thorns = card.thorns || 8;
                showFB('荆棘护盾！', 'special');
                break;

            // 护盾反弹
            case 'shield_reflect':
                G.shield += card.shield || 30;
                G.shieldReflect = true;
                showFB('守护反击！', 'special');
                break;

            // 不死
            case 'immortal':
                G.immortalTriggered = false;
                showFB('不死之身准备就绪！', 'special');
                break;

            // 治疗
            case 'heal':
                const healVal = Math.min(card.value || 12, G.player.maxHp - G.player.hp);
                G.player.hp += healVal;
                showFB(`恢复${healVal}血！`, 'success');
                break;

            // 伤害+治疗
            case 'damage_heal':
                if (enemy) dealDamage(enemy, card.value || 15);
                const heal2 = Math.min(card.heal || 10, G.player.maxHp - G.player.hp);
                G.player.hp += heal2;
                showFB(`治疗${heal2}血！`, 'success');
                break;

            // 吸血
            case 'lifesteal':
                G.lifesteal = card.value || 0.4;
                showFB(`吸血${Math.floor((card.value||0.4)*100)}%！`, 'info');
                break;

            // 献祭伤害
            case 'sacrifice_damage':
                const costHp1 = card.costHp || 12;
                G.player.hp -= costHp1;
                if (enemy) {
                    dealDamage(enemy, card.value || 25);
                    if (G.lifesteal) {
                        const ls = Math.floor((card.value || 25) * G.lifesteal);
                        G.player.hp = Math.min(G.player.maxHp, G.player.hp + ls);
                    }
                }
                break;

            // 献祭AOE
            case 'sacrifice_aoe':
                const costHp2 = card.costHp || 25;
                G.player.hp -= costHp2;
                G.enemies.filter(e => e.hp > 0).forEach(e => dealDamage(e, card.value || 30));
                break;

            // 献祭大
            case 'sacrifice_big':
                const costPct = card.costPct || 0.4;
                const costHp3 = Math.floor(G.player.hp * costPct);
                G.player.hp -= costHp3;
                if (enemy) dealDamage(enemy, card.value || 50);
                break;

            // 献祭增益
            case 'sacrifice_buff':
                G.player.hp -= card.costHp || 8;
                G.damageBuff = Math.max(G.damageBuff, 0);
                G.player.atk += card.value || 10;
                showFB(`消耗血量，攻击+${card.value||10}！`, 'special');
                break;

            // 血魔大法
            case 'blood_demon':
                G.bloodDemonAtk = Math.min(Math.floor(G.player.maxHp - G.player.hp) * (card.value || 0.5), 50);
                G.lifesteal = card.lifesteal || 0.3;
                showFB(`血魔！攻击+${G.bloodDemonAtk}，吸血30%`, 'special');
                break;

            // 反伤
            case 'revenge_all':
                G.revengeAll = true;
                showFB('反伤60%！', 'special');
                break;

            // 伤害+反伤
            case 'damage_revenge':
                if (enemy) dealDamage(enemy, card.value || 12);
                G.revengeBuff = Math.max(G.revengeBuff, card.revengePct || 0.3);
                showFB(`反伤${Math.floor((card.revengePct||0.3)*100)}%！`, 'info');
                break;

            // 免疫
            case 'immune':
                G.immune = true;
                showFB('金刚不坏！免疫本回合伤害', 'special');
                break;

            // 低血多段攻击
            case 'lowhp_multihit':
                if (G.player.hp / G.player.maxHp < 0.1) {
                    for (let i = 0; i < 4; i++) {
                        const hitDmg = Math.floor(Math.random() * 11) + 5; // 5-15
                        if (enemy) dealDamage(enemy, hitDmg);
                    }
                    showFB('天地同寿！4连击！', 'special');
                } else {
                    showFB('生命值需低于10%！', 'fail');
                }
                break;

            // 护甲叠加
            case 'armor_stack':
                G.player.def += card.value || 2;
                showFB(`防御+${card.value||2}！`, 'info');
                break;

            // 击杀攻击
            case 'kill_atk':
                G.attackBonusPermanent = (G.attackBonusPermanent || 0) + (card.value || 3);
                showFB(`永久攻击+${card.value||3}！`, 'special');
                break;
        }
    }

    function dealDamage(enemy, baseDmg, mode = 0, ignoreDefPct = 0, forceCrit = false) {
        if (!enemy || enemy.hp <= 0) return 0;

        // 闪避判定
        if (mode === 0 && !forceCrit && Math.random() < (enemy.canEvade ? 0.3 : 0.1)) {
            showDmgPop(0, 'miss');
            return 0;
        }

        let dmg = baseDmg;
        // 攻击增益
        const atkBonus = G.damageBuff + (G.attackCountBonus > 0 ? G.attackCountBonus / 10 : 0) + G.bloodDemonAtk / 100;
        dmg = Math.floor(dmg * (1 + atkBonus));
        // 忽视防御
        const defReduction = enemy.def * (1 - ignoreDefPct);
        dmg = Math.floor(dmg * (1 - defReduction / (defReduction + 30)));
        // 标记增伤
        if (enemy.marked) dmg = Math.floor(dmg * 1.8);
        // 暴击
        const critRate = 0.12 + G.critBuff;
        const isCrit = forceCrit || Math.random() < critRate;
        if (isCrit) {
            dmg = Math.floor(dmg * (2 + G.critDmgBonus));
            showDmgPop(dmg, 'crit');
        } else {
            showDmgPop(dmg, 'dmg');
        }

        enemy.hp -= dmg;

        // 吸血
        if (G.lifesteal) {
            const ls = Math.floor(dmg * G.lifesteal);
            G.player.hp = Math.min(G.player.maxHp, G.player.hp + ls);
        }

        // 荆棘
        if (G.thorns > 0 && enemy.hp > 0) {
            enemy.hp -= G.thorns;
            showDmgPop(G.thorns, 'reflect');
        }

        return dmg;
    }

    function showDmgPop(amt, type) {
        const enemyCards = document.querySelectorAll('.enemy-card:not(.dead)');
        if (enemyCards.length === 0) return;
        const targetCard = enemyCards[G.targetEnemy !== null && G.enemies[G.targetEnemy]?.hp > 0 ? G.targetEnemy : 0];
        if (!targetCard) return;

        const pop = document.createElement('div');
        pop.className = `dmg-pop ${type}`;
        pop.textContent = type === 'miss' ? '闪避' : type === 'crit' ? `${amt}!` : type === 'reflect' ? `刺${amt}` : `-${amt}`;
        pop.style.left = '60%'; pop.style.top = '30%';
        pop.style.transform = 'translateX(-50%)';
        targetCard.style.position = 'relative';
        targetCard.appendChild(pop);
        setTimeout(() => pop.remove(), 800);
    }

    function checkDead() {
        // 中毒
        G.enemies.forEach(e => {
            if (e.poison > 0 && e.poisonTurns > 0) {
                e.hp -= e.poison;
                e.poisonTurns--;
                showFB(`${e.name}中毒-${e.poison}！`, 'special');
                if (e.poisonTurns <= 0) e.poison = 0;
            }
            if (e.marked && e.markedTurns > 0) {
                e.markedTurns--;
                if (e.markedTurns <= 0) e.marked = false;
            }
        });

        // 敌人死亡
        const dead = G.enemies.filter(e => e.hp <= 0);
        G.enemies = G.enemies.filter(e => e.hp > 0);
        dead.forEach(e => {
            G.gold += e.gold;
            showFB(`击杀${e.name}！+${e.gold}银`, 'success');
            if (G.attackBonusPermanent) {
                G.player.atk += G.attackBonusPermanent;
                showFB(`血刃！攻击+${G.attackBonusPermanent}`, 'special');
            }
            if (G.chainUsed) {
                // 独孤九剑重置 - 暂用此逻辑
                G.chainUsed = false;
            }
        });

        G.targetEnemy = G.enemies.length > 0 ? G.enemies.findIndex(e => e.hp > 0) : null;

        // 检查波次
        if (G.enemies.length === 0) {
            if (G.wave >= G.maxWave) {
                endChapter();
            } else {
                G.wave++;
                showWaveBanner(`第 ${G.wave} 波`);
                spawnEnemies();
                // 可能触发事件
                if (Math.random() < 0.5) setTimeout(() => triggerEvent(), 500);
            }
        }

        // 检查玩家死亡
        if (G.player.hp <= 0) {
            G.player.hp = 0;
            endRun(false);
        }

        renderAll();
    }

    function useHeal() {
        if (G.healPots <= 0) { showFB('没有丹药！', 'fail'); return; }
        G.healPots--;
        const heal = Math.min(50, G.player.maxHp - G.player.hp);
        G.player.hp = Math.min(G.player.maxHp, G.player.hp + 50);
        showFB(`丹药！+${heal}血`, 'success');
        renderAll();
    }

    function endTurn() {
        // 清空临时增益
        G.damageBuff = 0;
        G.critBuff = 0;
        G.critDmgBonus = 0;
        G.attackCountBonus = 0;
        G.revengeAll = false;

        // 闪避回合递减
        if (G.evadeBuffTurns > 0) {
            G.evadeBuffTurns--;
            if (G.evadeBuffTurns <= 0) G.evadeBuff = 0;
        }

        // 敌人攻击
        G.enemies.filter(e => e.hp > 0).forEach(e => {
            // 闪避判定
            const totalEvade = G.player.evade + G.evadeBuff;
            if (Math.random() < totalEvade) {
                showFB(`闪避${e.name}攻击！`, 'success');
                // 闪避反击(武僧)
                if (G.revengeBuff > 0) {
                    e.hp -= Math.floor(G.player.atk * G.revengeBuff);
                    showFB(`反击${e.name}！`, 'special');
                }
                return;
            }

            if (G.immune) {
                G.immune = false;
                showFB('免疫伤害！', 'special');
                return;
            }

            let dmg = Math.floor(e.atk * (1 - G.player.def / (G.player.def + 30)));
            // 护盾
            if (G.shield > 0) {
                const absorb = Math.min(G.shield, dmg);
                G.shield -= absorb;
                dmg -= absorb;
                if (G.shieldReflect && dmg > 0) {
                    const alive = G.enemies.filter(en => en.hp > 0 && en !== e);
                    if (alive.length > 0) {
                        const target = alive[Math.floor(Math.random() * alive.length)];
                        target.hp -= dmg;
                        showFB(`护盾反弹${dmg}！`, 'special');
                    }
                    dmg = 0;
                }
            }
            // 死亡之身
            if (G.player.hp - dmg <= 0 && G.immortalTriggered === false) {
                G.player.hp = 1;
                G.immortalTriggered = true;
                G.shield += 15;
                G.enemies.filter(en => en.hp > 0)[0] && (G.enemies.filter(en => en.hp > 0)[0].hp -= 20);
                showFB('不死之身触发！', 'special');
                return;
            }
            // 反伤
            if (G.revengeBuff > 0) {
                e.hp -= Math.floor(dmg * G.revengeBuff);
            }
            G.player.hp -= dmg;
            showFB(`-${dmg}血！`, 'fail');
        });

        // 弃牌
        G.discard.push(...G.hand);
        G.hand = [];

        // 重置
        G.energy = G.maxEnergy;
        G.turn++;
        G.targetEnemy = null;

        // 抽牌
        drawCards(3);

        if (G.player.hp <= 0) { G.player.hp = 0; endRun(false); }

        renderAll();
    }

    function endChapter() {
        G.permanent.bestChapter = Math.max(G.permanent.bestChapter, G.chapter);
        if (G.chapter >= G.maxChapter) {
            G.permanent.wins++;
            showModal('🏆', '通关成功！', `恭喜带领「${G.player.name}」通关全部章节！\n💰 获得银两：${G.gold}`, [
                { name: '再来一局', effect: () => { hideModal(); showScreen('screenMain'); updateMain(); }}
            ]);
        } else {
            showModal('📜', '章节完成', `「${G.player.name}」完成了第${G.chapter}章！\n💰 银两：${G.gold}`, [
                { name: '继续下一章', effect: () => { hideModal(); nextChapter(); }},
                { name: '返回', effect: () => { hideModal(); showScreen('screenMain'); updateMain(); }}
            ]);
        }
        saveData();
    }

    function nextChapter() {
        G.chapter++;
        G.wave = 1;
        G.turn = 1;
        G.gold += 50; // 章节奖励
        // 恢复
        G.player.hp = G.player.maxHp;
        resetBattleState();
        // 选卡
        showCardPick();
    }

    function showCardPick() {
        const cls = CLASSES[G.player.class];
        const pool = cls.unlockPool.filter(id => !(G.permanent.unlockedCards || []).includes(id));
        if (pool.length === 0) {
            G.gold += 80;
            showFB('无新卡可解锁，+80银', 'info');
            startNextChapter();
            return;
        }

        // 选3张
        const picks = [];
        const temp = [...pool];
        for (let i = 0; i < 3 && temp.length > 0; i++) {
            const idx = Math.floor(Math.random() * temp.length);
            picks.push(temp.splice(idx, 1)[0]);
        }

        const container = document.getElementById('pickCards');
        container.innerHTML = '';
        picks.forEach(id => {
            const card = ALL_CARDS[id];
            const rarityClass = card.rarity === 'legend' ? 'legend' : card.rarity === 'epic' ? 'epic' : 'rare';
            container.innerHTML += `
                <div class="pick-card" onclick="pickCard('${id}')">
                    <div class="pick-card-icon">${card.icon}</div>
                    <div class="pick-card-info">
                        <div class="pick-card-name">${card.name} <span class="pick-card-rarity ${rarityClass}">${card.rarity === 'legend' ? '传说' : card.rarity === 'epic' ? '史诗' : '稀有'}</span></div>
                        <div class="pick-card-type">${card.type === 'attack' ? '攻击' : card.type === 'defense' ? '防御' : card.type === 'mobility' ? '机动' : '特殊'}</div>
                        <div class="pick-card-effect">${card.desc}</div>
                    </div>
                </div>
            `;
        });

        document.getElementById('cardPick').style.display = 'flex';
    }

    function pickCard(id) {
        G.permanent.unlockedCards = [...(G.permanent.unlockedCards || []), id];
        saveData();
        document.getElementById('cardPick').style.display = 'none';
        const card = ALL_CARDS[id];
        showFB(`获得「${card.name}」！永久解锁`, 'success');
        startNextChapter();
    }

    function startNextChapter() {
        G.wave = 1;
        G.turn = 1;
        resetBattleState();
        G.deck = [...G.deck, ...G.hand, ...G.discard];
        G.hand = []; G.discard = [];
        drawCards(5);
        spawnEnemies();
        renderAll();
        showWaveBanner(`章节 ${G.chapter} - 第 ${G.wave} 波`);
        if (Math.random() < 0.4) setTimeout(() => triggerEvent(), 500);
    }

    function endRun(victory) {
        if (victory) {
            G.permanent.wins++;
        }
        saveData();
        showModal(victory ? '🏆' : '💀', victory ? '通关成功！' : '阵亡', `「${G.player.name}」倒下...\n💰 银两：${G.gold}`, [
            { name: '再来一局', effect: () => { hideModal(); showScreen('screenMain'); updateMain(); }}
        ]);
    }

    // ==================== 事件 ====================
    function triggerEvent() {
        const ev = EVENTS[Math.floor(Math.random() * EVENTS.length)];
        showModal(ev.icon, ev.title, ev.desc, ev.choices);
    }

    function showModal(icon, title, desc, choices) {
        document.getElementById('mIcon').textContent = icon;
        document.getElementById('mTitle').textContent = title;
        document.getElementById('mDesc').textContent = desc;
        const cEl = document.getElementById('mChoices');
        cEl.innerHTML = '';
        choices.forEach(c => {
            const btn = document.createElement('div');
            btn.className = 'choice-btn';
            btn.innerHTML = `
                <div class="choice-name">${c.name}</div>
                <div class="choice-desc">${c.desc || ''}</div>
                ${c.cost ? `<div class="choice-cost">${c.cost > 0 ? `消耗 ${c.cost} 银两` : `消耗 ${Math.abs(c.cost)} 银两 + 奖励`}</div>` : ''}
            `;
            btn.onclick = () => {
                if (c.cost > 0 && G.gold < c.cost) { showFB('银两不足！', 'fail'); return; }
                c.effect(G);
                hideModal();
                renderAll();
            };
            cEl.appendChild(btn);
        });
        document.getElementById('modal').style.display = 'flex';
    }

    function hideModal() { document.getElementById('modal').style.display = 'none'; }

    function showWaveBanner(text) {
        const b = document.createElement('div');
        b.className = 'wave-banner';
        b.textContent = text;
        document.body.appendChild(b);
        setTimeout(() => b.remove(), 1500);
    }

    function showFB(text, type) {
        const el = document.getElementById('feedback');
        el.innerHTML = `<div class="fb-text ${type}">${text}</div>`;
        setTimeout(() => { if (el) el.innerHTML = ''; }, 2200);
    }

    // ==================== 启动 ====================
    initGame();
    loadData();
    updateMain();
    showClassSelect();
    </script>
</body>
</html>
